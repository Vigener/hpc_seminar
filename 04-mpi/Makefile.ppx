.PHONY: build-ppx benchmark-ppx

PPX_PROCS ?= 1 2 4 8 16
PPX_REPEATS ?= 10
PPX_ON_ERROR ?= stop
PPX_RAW_CSV ?=

PPX_OUTPUT_ARG :=
ifneq ($(strip $(PPX_RAW_CSV)),)
PPX_OUTPUT_ARG := --output $(PPX_RAW_CSV)
endif

build-ppx:
	@$(MAKE) -f Makefile release

benchmark-ppx: build-ppx
	@bash scripts/benchmark_ppx_raw.sh \
		--procs "$(PPX_PROCS)" \
		--repeats "$(PPX_REPEATS)" \
		--on-error "$(PPX_ON_ERROR)" \
		$(PPX_OUTPUT_ARG)
