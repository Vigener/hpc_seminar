{
    "name": "HPC Seminar",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/devcontainer/${localWorkspaceFolderBasename},type=bind",
    "workspaceFolder": "/devcontainer/${localWorkspaceFolderBasename}",
    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind",
        "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,ro"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "editor.formatOnSave": true,
                "C_Cpp.default.compilerPath": "/usr/bin/gcc"
            },
            "extensions": ["ms-vscode.cpptools", "github.copilot"]
        }
    },
    "remoteUser": "vscode"
}
